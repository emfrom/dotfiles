[init]
	defaultBranch = main
[user]
	email = vertlaforet@protonmail.com
	name = emfrom
	signinkey = /home/emfrom/.ssh/id_ed25519.pub
[github]
	user = emfrom
[credential]
	helper = store
[core]
	autocrlf = false

[push]
	autoSetupRemote = true
[rerere]
	enabled = true
[gpg]
	format = ssh
	program = /usr/bin/ssh-keygen
# [commit]
#	gpgSign = true

[filter "tabs-and-crlf"]
    clean = "sed -e 's/\\t/  /g' -e 's/\\r$//'"
    smudge = "sed -e 's/\\t/  /g' -e 's/\\r$//'"
[filter "krstyle"]
    clean = "indent -kr -i4 -nut"
    smudge = "indent -kr -i2 -nut"

[fetch]
	writeCommitGraph = true
	[alias]
	co = checkout
	br = branch
	st = status
	ci = commit
	# Commit helpers
	cm = commit -m
	ca = commit --amend
	aa = add .
	ad = add

# Push / Pull
ps = push
pl = pull
fe = fetch
cl = clone

# Branch switching
sw = switch
sc = switch -c

# Merging / Rebasing
me = merge
rb = rebase
cp = cherry-pick

# History / Inspection
lg = log --oneline --graph --decorate --all
df = diff
sh = show
bl = blame
rl = reflog

# Reset / Restore
re = reset
rh = reset --hard
rs = restore

# Stash
ss = stash
sp = stash pop

# Remote
rm = remote
rv = remote -v
pa = push --all
pt = push --tags

# old ones
unstage = reset HEAD --
	last = log -1 HEAD
	blame = blame -w -C -C -C
[pull]
	rebase = true
[pager]
	branch = false
	core = false
